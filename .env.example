# FHIR Terminology Server to connect to
FHIR_TERMINOLOGY_SERVER_URL=https://tx.fhir.org/r4

# Optional: in-memory Least recently used +TTL cache for deterministic operations ($lookup, $validate-code, …)
# FHIR_HTTP_CACHE_ENABLED=true
# FHIR_HTTP_CACHE_TTL_SECONDS=300
# FHIR_HTTP_CACHE_MAX_ENTRIES=512

# MCP Wrapper Configuration
MCP_SERVER_NAME=FHIR Terminology Server MCP Wrapper
MCP_TRANSPORT=stdio
MCP_PORT=8000
